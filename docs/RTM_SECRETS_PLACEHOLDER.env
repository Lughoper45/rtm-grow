# =============================================================================
# RTM Platform — Secrets placeholder (COPY VALUES TO SUPABASE + VERCEL)
# =============================================================================
# 1. Copy this file to RTM_SECRETS.local.env (gitignored) and fill every value.
# 2. Supabase Dashboard → Project kajwpmyloxaqeciyndwf → Edge Functions → Secrets
# 3. Vercel: only VITE_* vars on frontend projects (see .env.example)
# 4. Never commit RTM_SECRETS.local.env
# =============================================================================

# --- Required for listing outreach + email (minimum viable) ---

# Resend: https://resend.com/api-keys — domain must verify rtmbusinessdirectory.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Random long string — same value for cron jobs calling ops-dispatcher / enricher
OPS_CRON_SECRET=generate-a-long-random-string-here

# Canonical site URL (no trailing slash)
SITE_URL=https://www.rtmbusinessdirectory.com

# Max claim-invite emails per calendar day (default 50)
LISTING_DAILY_SEND_CAP=50

# --- Supabase (auto-injected on edge deploy; set locally for scripts only) ---
SUPABASE_URL=https://kajwpmyloxaqeciyndwf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.PASTE_ANON_KEY

# --- Cross-app URLs (edge functions use these in emails) ---
MEMBERSHIP_APP_URL=https://membership.rtmbusinessdirectory.com
GRANTS_APP_URL=https://grants.rtmbusinessdirectory.com
GRANTS_PAGE_URL=https://www.rtmbusinessdirectory.com/grants
GRANT_CHECKLIST_PDF_URL=https://www.rtmbusinessdirectory.com/downloads/RTM_Grant_Checklist.pdf
GRANT_CHECKLIST_NOTIFY_EMAIL=info@rtmbusinessdirectory.com
SITE_CONTACT_EMAIL=info@rtmbusinessdirectory.com
SITE_CONTACT_PHONE=+1 416 900 8728

# --- Stripe (membership + grant packages) ---
STRIPE_SECRET_KEY=sk_live_or_sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# --- Platform service key (cross-app edge calls) ---
PLATFORM_SERVICE_KEY=generate-another-long-random-string

# --- Social publishing (optional — without these, posts are dry-run logged) ---

# Meta: Facebook Page feed — developers.facebook.com → Page access token
META_PAGE_ACCESS_TOKEN=
# Numeric Facebook Page ID (Page Settings → About)
META_PAGE_ID=

# LinkedIn: Marketing API — post as organization
# Create app at https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=
# Example: urn:li:organization:12345678
LINKEDIN_ORGANIZATION_URN=

# X (Twitter) API v2 — Bearer token with tweet.write scope
# https://developer.x.com/
X_API_BEARER_TOKEN=

# --- Contact enrichment (optional) ---

# Google Cloud → Places API (Find Place + Details)
GOOGLE_PLACES_API_KEY=

# --- AI (optional — social copy + grant assistant) ---

# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# --- Slack / Discord ops alerts (optional future) ---
OPS_SLACK_WEBHOOK_URL=
OPS_DISCORD_WEBHOOK_URL=

# =============================================================================
# QUICK CHECKLIST AFTER FILLING
# =============================================================================
# [ ] RESEND_API_KEY + DNS (SPF/DKIM) on rtmbusinessdirectory.com
# [ ] OPS_CRON_SECRET set + daily cron POST to /functions/v1/ops-dispatcher
# [ ] db push: 20260525100000 + 20260525120000 migrations
# [ ] Deploy: listing-contact-enricher, listing-admin-bff, listing-public, ops-dispatcher
# [ ] Test: /admin/listings → enrich → queue → approve → dispatcher
# [ ] Optional: META_* / LINKEDIN_* / X_* for live social posts
# [ ] Optional: GOOGLE_PLACES_API_KEY for better contact discovery
