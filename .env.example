# Supabase — project kajwpmyloxaqeciyndwf (shared with membership app)
VITE_SUPABASE_PROJECT_ID=kajwpmyloxaqeciyndwf
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=https://kajwpmyloxaqeciyndwf.supabase.co

VITE_STRIPE_PUBLISHABLE_KEY=
VITE_SITE_URL=https://rtmbusinessdirectory.com

# Cross-app URLs (subdomains)
VITE_MEMBERSHIP_APP_URL=https://membership.rtmbusinessdirectory.com
VITE_GRANTS_APP_URL=https://grants.rtmbusinessdirectory.com
VITE_GROW_APP_URL=https://grow.rtmbusinessdirectory.com
VITE_WORLDCUP_APP_URL=https://worldcup.rtmbusinessdirectory.com
# Local grow subdomain dev: VITE_APP_SURFACE=grow (see npm run dev:grow)

# Directory data mode: hybrid | database | local
VITE_DIRECTORY_SOURCE_MODE=hybrid
VITE_SHOW_DIRECTORY_SOURCE_NOTICE=false

# Server-only — configure in Supabase secrets / CI, not VITE_*
SITE_URL=https://rtmbusinessdirectory.com
GROW_APP_URL=https://grow.rtmbusinessdirectory.com
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PLATFORM_SERVICE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_YEAR=
STRIPE_PRICE_PREMIUM_YEAR=
STRIPE_PRICE_PRO_YEAR=
RESEND_API_KEY=
# Listing outreach + ops dispatcher (Supabase secrets — see docs/RTM_SECRETS_PLACEHOLDER.env)
OPS_CRON_SECRET=
LISTING_DAILY_SEND_CAP=50
GRANTS_PAGE_URL=https://www.rtmbusinessdirectory.com/grants
GRANT_CHECKLIST_PDF_URL=https://www.rtmbusinessdirectory.com/downloads/RTM_Grant_Checklist.pdf
# Social publish (optional — without these, posts are dry-run in logs)
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=
X_API_BEARER_TOKEN=
GOOGLE_PLACES_API_KEY=
# OpenRouter — sole AI provider (edge secrets only — never commit keys)
# Validate model: node scripts/test-openrouter-model.mjs (requires OPENROUTER_API_KEY in env)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Grant OS dashboard tools (grant-os-tools edge function — same kajwp project)
# Used by grants.rtmbusinessdirectory.com for analytics, customers, compliance, research, reports
# Set in Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets):
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# GOOGLE_PLACES_API_KEY=          # optional: enrich find-customers with Places API later
